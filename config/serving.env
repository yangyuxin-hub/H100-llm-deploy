# ============================================================================
# LLM 部署共享配置 - 双模型并行部署(Qwen3.6-27B-FP8 + Agents-A1-FP8)
# 部署模式:两个模型同时运行,各占 2 张 H100(TP=2),不同端口
# 推理框架:vLLM 0.24.0 (Docker: vllm/vllm-openai:v0.24.0-cu129-ubuntu2404)
# 运维约束:不允许重启机器,只允许 docker 容器级操作
# 学习笔记: docs/learning-notes/04-dual-model-parallel-deployment.md
# ============================================================================

# ----- 路径配置 -----
# 项目根目录(远程 root 用户下运行部署脚本)
PROJECT_ROOT="/root/llm-deploy"

# 模型权重根目录(远程 H100 服务器)
MODEL_ROOT="/mnt/nvme0/models"

# CUDA forward compatibility 用户态库路径。
# 远程 driver 550.144.03 不升级、不重启；vLLM 0.24.0 的 CUDA 12.9 栈需要优先加载该目录下的 libcuda。
CUDA_COMPAT_LIB_DIR="/mnt/nvme0/cuda-compat-12-9-extract/usr/local/cuda-12.9/compat"

# 当前驱动下 vLLM custom all-reduce CUDA 扩展会报 cudaErrorInsufficientDriver。
# 默认禁用并回退 NCCL all-reduce，不影响 TP 功能。
DISABLE_CUSTOM_ALL_REDUCE=1

# vLLM 0.24.0 默认会对 DeepGEMM 做启动预热；当前 driver 550 + CUDA 12.9 用户态库下，
# 该预热 JIT 会触发 cudaErrorInsufficientDriver。先跳过预热以跑通服务。
VLLM_DEEP_GEMM_WARMUP="skip"

# 运行时目录(PID 文件)
RUNTIME_DIR="${PROJECT_ROOT}/runtime"

# 日志目录
LOG_DIR="${PROJECT_ROOT}/logs"

# ----- GPU 分组(项目首次使用 CUDA_VISIBLE_DEVICES 限制具体 GPU) -----
QWEN_FP8_CUDA_VISIBLE_DEVICES=0,1
AGENTS_CUDA_VISIBLE_DEVICES=2,3

# ----- Qwen3.6-27B-FP8 配置 -----
# 官方文档: https://huggingface.co/Qwen/Qwen3.6-27B-FP8
QWEN_FP8_MODEL_PATH="${MODEL_ROOT}/Qwen3.6-27B-FP8"
QWEN_FP8_MODELSCOPE_ID="Qwen/Qwen3.6-27B-FP8"
QWEN_FP8_SERVED_NAME="qwen3.6-27b-fp8"
QWEN_FP8_DOCKER_CONTAINER_NAME="qwen3.6-27b-fp8"
QWEN_FP8_SERVE_PORT=8000
QWEN_FP8_TENSOR_PARALLEL_SIZE=2
QWEN_FP8_MAX_MODEL_LEN=262144
QWEN_FP8_GPU_MEM_UTIL=0.90
QWEN_FP8_MAX_NUM_SEQS=16
QWEN_FP8_MAX_NUM_BATCHED_TOKENS=65536
QWEN_FP8_KV_CACHE_DTYPE="fp8"
QWEN_FP8_ATTENTION_BACKEND="flashinfer"
QWEN_FP8_SPECULATIVE_CONFIG='{"method":"qwen3_next_mtp","num_speculative_tokens":2}'
QWEN_FP8_REASONING_PARSER="qwen3"
QWEN_FP8_TOOL_PARSER="qwen3_coder"
# 跳过 vision encoder,释放显存给 KV cache(纯文本场景)
QWEN_FP8_LANGUAGE_MODEL_ONLY=1
# 采样参数(官方推荐:精确编码模式 + 81920 输出)
QWEN_FP8_OVERRIDE_GENERATION_CONFIG='{"temperature":0.6,"top_p":0.95,"top_k":20,"max_tokens":81920}'

# ----- Agents-A1-FP8 配置 -----
# 架构: Qwen3_5MoeForConditionalGeneration,FP8 量化(compressed-tensors)
# 官方推荐配置: https://huggingface.co/InternScience/Agents-A1-FP8
AGENTS_MODEL_PATH="${MODEL_ROOT}/Agents-A1-FP8"
AGENTS_MODELSCOPE_ID="InternScience/Agents-A1-FP8"
AGENTS_SERVED_NAME="agents-a1-fp8"
AGENTS_DOCKER_CONTAINER_NAME="agents-a1-fp8-vllm"
AGENTS_SERVE_PORT=8001
AGENTS_TENSOR_PARALLEL_SIZE=2
AGENTS_MAX_MODEL_LEN=262144
AGENTS_GPU_MEM_UTIL=0.90
AGENTS_KV_CACHE_DTYPE="fp8"
AGENTS_ATTENTION_BACKEND="FLASH_ATTN"
# MTP 投机解码(模型 config.json 有 mtp_num_hidden_layers=1,支持 MTP)
AGENTS_SPECULATIVE_CONFIG='{"method":"qwen3_next_mtp","num_speculative_tokens":2}'
# Function Calling 支持(官方推荐 qwen3_coder parser)
AGENTS_REASONING_PARSER="qwen3"
AGENTS_TOOL_PARSER="qwen3_coder"
# 采样参数(官方推荐: https://huggingface.co/InternScience/Agents-A1-FP8)
AGENTS_OVERRIDE_GENERATION_CONFIG='{"temperature":0.85,"top_p":0.95,"top_k":20,"min_p":0.0,"presence_penalty":1.1,"repetition_penalty":1.0,"max_tokens":81920}'

# ----- 健康检查 -----
HEALTH_CHECK_URL_QWEN_FP8="http://127.0.0.1:${QWEN_FP8_SERVE_PORT}/v1/models"
HEALTH_CHECK_URL_AGENTS="http://127.0.0.1:${AGENTS_SERVE_PORT}/v1/models"
HEALTH_CHECK_TIMEOUT=600          # 启动后等待 ready 的超时(秒)
HEALTH_CHECK_INTERVAL=10          # 轮询间隔(秒)

# ----- Docker 配置 -----
# 使用 vLLM 官方 OpenAI-compatible Docker 镜像，不自建镜像、不把模型权重打进镜像。
# 模型通过 -v ${MODEL_ROOT}:${MODEL_ROOT}:ro 从宿主机只读挂载进容器。
# cu129 镜像原生兼容 driver 550，无需 cuda-compat 层。
VLLM_DOCKER_IMAGE="vllm/vllm-openai:v0.24.0-cu129-ubuntu2404"
VLLM_DOCKER_ENABLE_CUDA_COMPATIBILITY=0

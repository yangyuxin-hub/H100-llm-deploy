# ============================================================================
# LLM 部署共享配置 - Qwen3.6-27B-FP8 / DeepSeek-V4-Flash-DSpark
# 部署模式:互斥部署(同一时刻仅运行一个模型,4 卡优先使用 TP=4,DP=1)
# 推理框架:vLLM (>=0.19.0)
# ============================================================================

# ----- 路径配置 -----
# 项目根目录(本文件位于 $PROJECT_ROOT/config/serving.env)
PROJECT_ROOT="/home/yangyuxin/llm-deploy"

# 模型权重根目录(下载到这里)
MODEL_ROOT="${PROJECT_ROOT}/models"

# Qwen3.6-27B-FP8 模型路径
MODEL_PATH_QWEN="${MODEL_ROOT}/Qwen3.6-27B-FP8"
QWEN_MODELSCOPE_ID="Qwen/Qwen3.6-27B-FP8"
QWEN_SERVED_NAME="qwen3.6-27b-fp8"
# Qwen 用 layers-N.safetensors 命名(无 index.json),数量不固定
# 校验改为基于最小总大小(~28GB),不依赖固定分片数
QWEN_MIN_SIZE_GB=20

# DeepSeek-V4-Flash-DSpark 模型路径
MODEL_PATH_DS="${MODEL_ROOT}/DeepSeek-V4-Flash-DSpark"
DS_MODELSCOPE_ID="deepseek-ai/DeepSeek-V4-Flash-DSpark"
DS_SERVED_NAME="deepseek-v4-flash-dspark"
# DeepSeek 用 model-NNNNN-of-NNNNN.safetensors 命名
DS_SHARDS_EXPECTED=48     # README 已确认共 48 个 safetensors 分片

# 运行时目录(PID 文件)
RUNTIME_DIR="${PROJECT_ROOT}/runtime"

# 日志目录
LOG_DIR="${PROJECT_ROOT}/logs"

# ----- 服务配置 -----
# 两个模型互斥运行,复用同一端口
SERVE_PORT=8000

# GPU 配置:4x H100
# Qwen 优先使用 TP=4,DP=1,保证 MTP 和长上下文稳定性
TENSOR_PARALLEL_SIZE=4
DATA_PARALLEL_SIZE=1

# Qwen vLLM 参数
QWEN_MAX_MODEL_LEN=262144         # 原生上下文
QWEN_GPU_MEM_UTIL=0.90
QWEN_REASONING_PARSER="qwen3"
QWEN_TOOL_PARSER="qwen3_coder"
QWEN_ENABLE_MTP=1
QWEN_SPECULATIVE_CONFIG='{"method":"qwen3_next_mtp","num_speculative_tokens":2}'

# DeepSeek vLLM 参数
# 默认 65536,需要 1M 上下文时改为 1048576 并降低 GPU_MEM_UTIL
DS_MAX_MODEL_LEN=65536
DS_GPU_MEM_UTIL=0.92
# 移除 config.json 中可能干扰 vLLM 的 expert_dtype:"fp4" 字段
DS_HF_OVERRIDES='{"expert_dtype": null}'

# ----- 健康检查 -----
HEALTH_CHECK_URL="http://127.0.0.1:${SERVE_PORT}/v1/models"
HEALTH_CHECK_TIMEOUT=600          # 启动后等待 ready 的超时(秒)
HEALTH_CHECK_INTERVAL=10          # 轮询间隔(秒)

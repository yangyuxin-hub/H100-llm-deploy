  "sources": [
    {
      "id": "gap_notes",
      "label": "82 项模型评测覆盖差距：分析说明",
      "path": "docs/reports/archive/evaluation-planning/2026-07-14-benchmark-gap-analysis/notes.md",
      "query": {
        "engine": "SQLite JSON1",
        "language": "sql",
        "sql": "SELECT modality, category, benchmark, coverage_status, priority, local_component, result_status, missing_next FROM json_each(json_extract(CAST(readfile('docs/reports/archive/evaluation-planning/2026-07-14-benchmark-gap-analysis/artifact.json') AS TEXT), '$.snapshot.datasets.benchmark_gap_rows'))",
        "description": "按候选 benchmark 名称对照项目主套件、本地 EvalScope 1.6.1 注册表、ThinkingCap 数据 manifest 和已有评测结果。",
        "filters": [
          "候选集为用户提供的 82 个 benchmark 行",
          "近似名称不自动认定为严格等价",
          "DRY_RUN 与模型卡公开分数不计为本地结果"
        ],
        "metric_definitions": [
          "benchmark_count：各互斥接入状态下的 benchmark 行数",
          "主套件已接入：同名任务已写入 capability_suites.tsv",
          "部分接入：主套件已有近似任务，但版本、subset 或规模不完整",
          "EvalScope 已注册，待接入/对齐：本地 EvalScope 有同名或近似 adapter，但未进入主套件或协议未固定",
          "未接入：主套件与本地 EvalScope 注册表均无可直接对应任务"
        ]
      }
    },
    {
      "id": "benchmark_reference",
      "label": "Qwen3.5 模型卡评测分数参考表（用户提供）",
      "path": "docs/reports/archive/evaluation-references/2026-07-14-qwen35-benchmark-score-reference.md"
    },
    {
      "id": "capability_suite",
      "label": "EvalScope 项目能力主套件",
      "path": "benchmarks/evalscope/capability_suites.tsv"
    },
    {
      "id": "thinkingcap_preparation",
      "label": "ThinkingCap 数据准备状态",
      "path": "benchmarks/thinkingcap/PREPARATION_STATUS.md"
    },
    {
      "id": "mmlu_pilot",
      "label": "ThinkingCap 能力评测报告",
      "path": "docs/reports/archive/evaluation-results/2026-07-13-thinkingcap-capability-eval.md"
    }
  ]

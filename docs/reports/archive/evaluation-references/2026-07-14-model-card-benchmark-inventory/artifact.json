    {
      "id": "benchmark_inventory_notes",
      "label": "三张模型卡评测集清单：来源与整理说明",
      "path": "docs/reports/archive/evaluation-references/2026-07-14-model-card-benchmark-inventory/notes.md",
      "query": {
        "engine": "ANSI SQL",
        "language": "sql",
        "sql": "SELECT model, entry_count FROM (VALUES ('GLM-5.2', 19), ('ThinkingCap-Qwen3.6-27B', 21), ('Qwen3.5-122B-A10B', 82)) AS inventory(model, entry_count)",
        "description": "将逐行抄录的三张模型卡评测结果表汇总为覆盖条目数。",
        "filters": ["按模型卡结果行计数", "同一数据集的不同模式或 harness 保留为不同条目"],
        "metric_definitions": ["entry_count：模型卡 Benchmark 结果表中公开的结果行数，不代表唯一数据集数或模型能力"]
      }

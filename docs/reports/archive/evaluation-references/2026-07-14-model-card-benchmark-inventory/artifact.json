    {
      "id": "overlap_inventory",
      "label": "三张模型卡同名测试集交集",
      "path": "docs/reports/archive/evaluation-references/2026-07-14-model-card-benchmark-inventory/notes.md",
      "query": {
        "engine": "SQLite JSON1",
        "language": "sql",
        "sql": "SELECT json_extract(value, '$.benchmark') AS benchmark, json_extract(value, '$.glm') AS glm, json_extract(value, '$.thinkingcap') AS thinkingcap, json_extract(value, '$.qwen') AS qwen, json_extract(value, '$.comparability') AS comparability FROM json_each(json_extract(CAST(readfile('docs/reports/archive/evaluation-references/2026-07-14-model-card-benchmark-inventory/artifact.json') AS TEXT), '$.snapshot.datasets.overlap_rows'))",

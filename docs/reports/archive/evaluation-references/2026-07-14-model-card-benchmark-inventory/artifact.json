        "sql": "SELECT json_extract(value, '$.modality') AS modality, json_extract(value, '$.category') AS category, json_extract(value, '$.benchmark') AS benchmark, json_extract(value, '$.score') AS score, json_extract(value, '$.note') AS note FROM json_each(json_extract(CAST(readfile('docs/reports/archive/evaluation-references/2026-07-14-model-card-benchmark-inventory/artifact.json') AS TEXT), '$.snapshot.datasets.qwen_rows'))",
